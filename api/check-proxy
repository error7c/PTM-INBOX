const { SocksProxyAgent } = require('socks-proxy-agent');
const axios = require('axios');

export default async function handler(req, res) {
    if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' });

    const pool = process.env.PROXY_POOL ? process.env.PROXY_POOL.split(',') : [];
    if (pool.length === 0) return res.status(500).json({ success: false, error: "PROXY_POOL is empty, Boss." });

    // Pick a random proxy for the test
    const selectedProxy = pool[Math.floor(Math.random() * pool.length)];
    const proxyUrl = `socks5h://${selectedProxy}`;
    
    try {
        const agent = new SocksProxyAgent(proxyUrl);
        const ipInfo = await axios.get('http://ip-api.com/json', { 
            httpAgent: agent, 
            httpsAgent: agent,
            timeout: 15000 
        });

        return res.status(200).json({
            success: true,
            ip: ipInfo.data.query,
            isp: ipInfo.data.isp,
            city: ipInfo.data.city,
            country: ipInfo.data.country,
            pool_size: pool.length
        });
    } catch (error) {
        return res.status(500).json({ success: false, error: "AWS Proxy Offline: " + error.message });
    }
}
