const { SocksProxyAgent } = require('socks-proxy-agent');
const axios = require('axios');

export default async function handler(req, res) {
    // 1. Handle CORS Preflight requests
    if (req.method === 'OPTIONS') {
        res.setHeader('Access-Control-Allow-Origin', '*');
        res.setHeader('Access-Control-Allow-Methods', 'POST, OPTIONS');
        res.setHeader('Access-Control-Allow-Headers', 'Content-Type');
        return res.status(200).end();
    }

    // 2. Log method for debugging in Vercel Dashboard
    console.log(`[P7M DEBUG] Method Received: ${req.method}`);

    if (req.method !== 'POST') {
        return res.status(405).json({ 
            success: false, 
            error: `Method ${req.method} Not Allowed. Use POST, Boss.` 
        });
    }

    const poolStr = process.env.PROXY_POOL || "";
    const pool = poolStr.split(',').filter(p => p.trim() !== "");
    
    if (pool.length === 0) {
        return res.status(500).json({ success: false, error: "PROXY_POOL env is empty." });
    }

    const selectedProxy = pool[Math.floor(Math.random() * pool.length)];
    const proxyUrl = `socks5h://${selectedProxy.trim()}`;
    
    try {
        const agent = new SocksProxyAgent(proxyUrl);
        const ipInfo = await axios.get('http://ip-api.com/json', { 
            httpAgent: agent, 
            httpsAgent: agent,
            timeout: 6000 
        });

        return res.status(200).json({
            success: true,
            ip: ipInfo.data.query,
            isp: ipInfo.data.isp,
            pool_size: pool.length
        });
    } catch (error) {
        console.error(`Proxy Error: ${selectedProxy.split('@')[1]} | ${error.message}`);
        return res.status(200).json({ 
            success: false, 
            error: `AWS Node Offline: ${error.message}` 
        });
    }
}
